{
  "name": "orion",
  "private": true,
  "version": "0.1.0-dev.1780090226",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "concurrently --names backend,frontend --prefix-colors blue,magenta \"pnpm --filter ./backend dev\" \"pnpm --filter ./frontend dev\"",
    "build": "pnpm --filter ./backend build && pnpm --filter ./frontend build",
    "preview": "pnpm --filter ./frontend preview",
    "lint": "pnpm --filter ./backend lint && pnpm --filter ./frontend lint",
    "format": "prettier --write \"backend/src/**/*.{ts,tsx,js,mjs,cjs,json}\" \"frontend/src/**/*.{ts,tsx,js,mjs,cjs,json,css}\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"backend/src/**/*.{ts,tsx,js,mjs,cjs,json}\" \"frontend/src/**/*.{ts,tsx,js,mjs,cjs,json,css}\" \"*.{json,md,yml,yaml}\"",
    "typecheck": "pnpm --filter ./backend typecheck && pnpm --filter ./frontend typecheck",
    "test": "pnpm --filter ./backend test && pnpm --filter ./frontend test",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "clean": "rm -rf backend/dist frontend/dist"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
