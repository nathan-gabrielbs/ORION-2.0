{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"]
    },
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
