NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# PostgreSQL connection (required). Local docker-compose defaults:
# postgresql://orion:orion_dev@localhost:5433/orion  (host port mapped in docker-compose)
DATABASE_URL=postgresql://orion:orion_dev@localhost:5433/orion

# Comma-separated list of allowed CORS origins.
# In production this is the single source of truth (no implicit LAN trust).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dev-only escape hatch: when set to "true" AND NODE_ENV != production,
# requests from RFC 1918 private ranges (10.x, 192.168.x, 172.16-31.x) are
# also accepted by CORS. Useful for testing the dashboard from a phone on
# the same Wi-Fi. Defaults to false. Ignored in production.
# CORS_ALLOW_PRIVATE_LAN=false

# ============================================
# AUTHENTICATION
# ============================================

# Orbital OIDC (SSO corporativo). The "Entrar com SSO" button delegates the
# corporate sign-in to Orbital (which fronts Microsoft). Without these four,
# only local email/password login is available.
OIDC_ISSUER=https://orbital.grpotencial.com.br/api
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must match the redirect_uri registered in the Orbital client (defaults to
# ${PUBLIC_BASE_URL}/auth/callback).
OIDC_REDIRECT_URI=
# Defaults to ${PUBLIC_BASE_URL}/login.
OIDC_POST_LOGOUT_REDIRECT_URI=
# OIDC_SCOPES=openid profile email offline_access orbital.roles orbital.profile orbital.microsoft orbital.permissions
# OIDC_REFRESH_LEEWAY_MS=60000
# Orbital role key that maps to the Orion ADMIN role.
# ORBITAL_ADMIN_ROLE_KEY=admin

# Secret for express-session (holds the Orbital token bundle between requests).
# REQUIRED in production. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Break-glass admin bootstrapped at boot as an Orbital identity (login is
# SSO-only). This email is always kept as ADMIN and is never demoted, so it can
# always sign in via Orbital and manage other admins.
BOOTSTRAP_ADMIN_EMAIL=admin@local.dev

# ============================================
# SIGHRA (SOAP telemetry + macros)
# ============================================
SIGHRA_WS_URL=
SIGHRA_USER=
SIGHRA_PASS=

# REQUIRED in production. The /api/sighra/webhook route bypasses session
# auth and trusted-origin checks, so without this token an attacker could
# push arbitrary lat/lng/speed for any plate. Compared in constant time.
SIGHRA_WEBHOOK_TOKEN=

# Verbose macro polling diagnostics (fetched count, skip breakdown, SOAP sample)
SIGHRA_MACROS_DEBUG=false

# ============================================
# RASTER (JSON trip / route service)
# ============================================
RASTER_BASE_URL=
RASTER_METHOD=getEventoFimViagem
RASTER_LOGIN=
RASTER_PASSWORD=
